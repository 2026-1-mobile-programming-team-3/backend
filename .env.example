# 애플리케이션
APP_ENV=development

# ─── DB 설정 ─────────────────────────────────────────────────────────────
# 두 가지 방식 중 하나로 설정. DATABASE_URL이 있으면 그걸 우선 사용.
#
# (1) DATABASE_URL을 통째로 (Railway/Render 같은 PaaS, 외부 매니지드 DB)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# (2) 부품으로 (로컬 docker-compose)
# POSTGRES_HOST 는 docker compose 환경에서는 'db', 로컬 직접 실행 시에는 'localhost'.
POSTGRES_USER=siheunggage
POSTGRES_PASSWORD=change-me
POSTGRES_DB=siheunggage
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis 세팅
REDIS_URL=redis://redis:6379/0

# JWT
# 비밀키는 openssl rand -hex 32 같은걸로 만드는 게 좋습니다.
JWT_SECRET_KEY=replace-with-random-secret-min-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SQLAdmin 관리자 계정 (기본값: admin / admin123! — 운영환경에서 반드시 변경)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123!
